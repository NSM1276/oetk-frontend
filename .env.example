# Скопируйте этот файл в .env.local и заполните значениями.
# .env.local в .gitignore — туда кладём настоящие секреты.

# Базовый URL Joomla Web Services REST API
JOOMLA_API_URL=http://s1091003060.online.de/api/index.php/v1

# Базовый URL Joomla-сайта (для построения путей к картинкам)
JOOMLA_SITE_URL=http://s1091003060.online.de

# API-токен из Joomla (Users → Manage → [user] → Joomla API Token)
JOOMLA_API_TOKEN=
